{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Token": {
    "Audience": "www.blogapp.com",
    "Issuer": "www.myapi.com",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30,
    "SecurityKey": ""
  },
  "Mail": {
    "Username": "",
    "Password": "",
    "Port": 587,
    "Host": "smtp.gmail.com",
    "FromName": "BlogAppTest"
  },
  "Seq": {
    "ServerURL": "http://localhost:5341/"
  },
  "SensitiveEndpointRateLimit": {
    "Policies": {
      "/api/Auth/login": {
        "PermitLimit": 10,
        "WindowSeconds": 60
      },
      "/api/User/register": {
        "PermitLimit": 5,
        "WindowSeconds": 600
      },
      "/api/Auth/forgotPassword": {
        "PermitLimit": 5,
        "WindowSeconds": 900
      },
      "/api/Auth/mailVerify": {
        "PermitLimit": 5,
        "WindowSeconds": 900
      },
      "/api/Auth/refreshTokenLogin": {
        "PermitLimit": 30,
        "WindowSeconds": 60
      },
      "/api/User/updatePassword": {
        "PermitLimit": 10,
        "WindowSeconds": 600
      },
      "/api/User/updateMailVerify": {
        "PermitLimit": 10,
        "WindowSeconds": 600
      }
    }
  }
}
